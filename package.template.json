{
  "name": "yaforecaswatch2",
  "author": "Matt Rossman",
  "version": "1.34.4",
  "buildProfile": "{{buildProfile}}",
  "keywords": [
    "pebble-app"
  ],
  "homepage": "https://github.com/Dreamkeeper/YaForecasWatch2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dreamkeeper/YaForecasWatch2.git"
  },
  "private": true,
  "dependencies": {
    "suncalc": "^1.9.0"
  },
  "pebble": {
    "displayName": "{{displayName}}",
    "uuid": "{{uuid}}",
    "sourceUrl": "https://github.com/Dreamkeeper/YaForecasWatch2",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "diorite",
      "emery",
      "flint"
    ],
    "watchapp": {
      "watchface": true
    },
    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "icon.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_MUTE",
          "file": "img/mute.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_DISCONNECT",
          "file": "img/bt-disconnect.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_CONNECT",
          "file": "img/bt.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BATTERY_CHARGING",
          "file": "img/battery-charging.png",
          "memoryFormat": "1BitPalette"
        }
      ]
    },
    "capabilities": [
      "location",
      "configurable"
    ],
    "messageKeys": [
      "TEMP_TREND_INT16",
      "PRECIP_TREND_UINT8",
      "UV_TREND_UINT8",
      "FORECAST_START",
      "NUM_ENTRIES",
      "CURRENT_TEMP",
      "CITY",
      "SUN_EVENTS",
      "WATCH_HAS_FORECAST_DATA",
      "DEBUG_FETCH_ERROR",
      "CLAY_CELSIUS",
      "CLAY_TIME_LEAD_ZERO",
      "CLAY_AXIS_12H",
      "CLAY_START_MON",
      "CLAY_COLOR_TODAY",
      "CLAY_PREV_WEEK",
      "CLAY_TIME_FONT",
      "CLAY_SHOW_QT",
      "CLAY_SHOW_BT",
      "CLAY_SHOW_BT_DISCONNECT",
      "CLAY_VIBE",
      "CLAY_SHOW_AM_PM",
      "CLAY_COLOR_SATURDAY",
      "CLAY_COLOR_SUNDAY",
      "CLAY_COLOR_US_FEDERAL",
      "CLAY_HOLIDAY_SET_1",
      "CLAY_HOLIDAY_SET_2",
      "CLAY_COLOR_HOLIDAY_1",
      "CLAY_COLOR_HOLIDAY_2",
      "CLAY_COLOR_TIME",
      "CLAY_DAY_NIGHT_SHADING",
      "HOLIDAY_SLOT",
      "HOLIDAY_SET",
      "HOLIDAY_YEAR",
      "HOLIDAY_BITS"
    ]
  }
}
